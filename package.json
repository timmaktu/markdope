{
  "name": "markdope",
  "version": "0.1.0",
  "description": "Rich YAML component blocks for Obsidian Markdown notes.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "markdown",
    "yaml",
    "react"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "esbuild": "0.25.5",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@codemirror/language": "6.10.8",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "obsidian": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  }
}
