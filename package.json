{
  "name": "markdope",
  "version": "0.1.0",
  "description": "Rich YAML component blocks for Obsidian Markdown notes.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "dev:styles": "tailwindcss -i ./src/styles/tailwind.css -o ./styles.css --watch",
    "build:styles": "tailwindcss -i ./src/styles/tailwind.css -o ./styles.css --minify",
    "build": "npm run build:styles && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "markdown",
    "yaml",
    "react"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.7",
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "esbuild": "0.25.5",
    "tailwindcss": "^4.1.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.4",
    "@codemirror/language": "6.10.8",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.511.0",
    "obsidian": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.3.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  }
}
